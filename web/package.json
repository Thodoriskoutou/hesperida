{
	"name": "hesperida-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "bun test --preload ./src/tests/helpers/preload.ts",
		"test:watch": "bun test --watch --preload ./src/tests/helpers/preload.ts",
		"test:api": "bun test ./src/tests/integration --preload ./src/tests/helpers/preload.ts"
	},
	"devDependencies": {
		"@fontsource-variable/roboto": "^5.2.10",
		"@fontsource-variable/roboto-slab": "^5.2.8",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.1.18",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.6",
		"svelte": "^5.54.0",
		"svelte-adapter-bun": "*",
		"svelte-check": "^4.4.2",
		"sveltekit-openapi-generator": "^0.1.5",
		"swagger-ui-dist": "^5.32.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"surrealdb": "^2.0.3"
	}
}
